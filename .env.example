OPENCLAW_MEMORY_PLUGIN_EMBEDDING_PROVIDER=local
OPENCLAW_MEMORY_PLUGIN_EMBEDDING_MODEL=text-embedding-3-small
OPENCLAW_MEMORY_PLUGIN_EMBEDDING_API_KEY=
OPENCLAW_MEMORY_PLUGIN_EMBEDDING_BASE_URL=https://api.openai.com/v1
OPENCLAW_MEMORY_PLUGIN_AUTO_WRITE=true
OPENCLAW_MEMORY_PLUGIN_CONTEXT_BUDGET=2400
OPENCLAW_MEMORY_PLUGIN_RECENT_TURNS=6
OPENCLAW_MEMORY_PLUGIN_MEMORY_TOP_K=6
OPENCLAW_MEMORY_PLUGIN_BOOT_TOP_K=4
OPENCLAW_MEMORY_PLUGIN_WRITE_THRESHOLD=5.2
OPENCLAW_MEMORY_PLUGIN_PREFERENCE_TTL_DAYS=180
OPENCLAW_MEMORY_PLUGIN_SEMANTIC_TTL_DAYS=120
OPENCLAW_MEMORY_PLUGIN_EPISODIC_TTL_DAYS=14
OPENCLAW_MEMORY_PLUGIN_SESSION_STATE_TTL_DAYS=21
OPENCLAW_MEMORY_PLUGIN_DEDUPE_SIMILARITY=0.92
OPENCLAW_MEMORY_PLUGIN_HTTP_PATH=/plugins/openclaw-memory-plugin
OPENCLAW_MEMORY_PLUGIN_PROFILE_STORE_DETAILS=true
